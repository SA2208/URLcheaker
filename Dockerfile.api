FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN groupadd --system urlchecker && useradd --system --gid urlchecker --create-home urlchecker
WORKDIR /app

COPY pyproject.toml README.md alembic.ini ./
COPY alembic ./alembic
COPY src ./src
COPY data ./data
RUN python -m pip install --upgrade pip && python -m pip install .

USER urlchecker
EXPOSE 8000
CMD ["uvicorn", "urlchecker.main:app", "--host", "0.0.0.0", "--port", "8000"]
