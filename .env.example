POSTGRES_PASSWORD=replace-with-a-random-secret
URLCHECKER_ENVIRONMENT=development
URLCHECKER_DATABASE_URL=sqlite+pysqlite:///./urlchecker.db
URLCHECKER_MODEL_BACKEND=heuristic
URLCHECKER_MODEL_PATH=ml/models/urlchecker_pycaret
URLCHECKER_MODEL_VERSION=heuristic-1.0.0
URLCHECKER_DATASET_VERSION=demo-synthetic-1
URLCHECKER_FEED_PATH=data/feeds/sample_feed.json
URLCHECKER_MALICIOUS_THRESHOLD=0.80
URLCHECKER_BENIGN_THRESHOLD=0.20
URLCHECKER_MAX_URL_LENGTH=4096
URLCHECKER_RATE_LIMIT_PER_MINUTE=60
URLCHECKER_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
URLCHECKER_STORE_FULL_URLS=false
URLCHECKER_MODEL_HMAC_KEY=
URLCHECKER_AUTO_CREATE_TABLES=true
